@model IEnumerable<ITSM.Models.Categoria>

@{
    ViewBag.Title = "Categoria";
}

<p class="btn btn-outline-primary">
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">

        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>

        </tr>


    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.Id }, new {@class = "btn btn-sm btn-primary"}) |
                @Html.ActionLink("Details", "Details", new { id = item.Id }, new { @class = "btn btn-sm btn-warning" }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.Id }, new { @class = "btn btn-sm btn-danger" })
            </td>
        </tr>
    }

</table>
