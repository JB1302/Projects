@model IEnumerable<ITSM.Models.Tiquete>

@{
    ViewBag.Title = "Index";
}

<p class="btn btn-outline-primary">
    @Html.ActionLink("Create New", "Create")
</p>

<!--Mostrar el dropdown para filtrar por estado -->
@using (Html.BeginForm("Index", "Tiquetes", FormMethod.Get))
{
    <div class="form-group">

        @Html.DropDownList(
            "estado",
            //Convierte el objeto dinámico guardado en ViewBag a SelectList para que el DropDownList lo pueda usar
            ViewBag.estado as SelectList,
            //Valor por defecto
            "Seleccione un estado",
            new
            {
                @class = "form-control",
                //Cuando se cambie enviar el formulario automaticamente
                onchange = "this.form.submit();"
            }
        )
    </div>
}



<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Titulo)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.Cliente.NombreCompleto)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.Categoria.Nombre)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.estado)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Titulo)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.Cliente.NombreCompleto)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.Categoria.Nombre)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.estado)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.Id }, new { @class = "btn btn-sm btn-primary" }) |
                @Html.ActionLink("Details", "Details", new { id = item.Id }, new { @class = "btn btn-sm btn-warning" }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.Id }, new { @class = "btn btn-sm btn-danger" })
            </td>
        </tr>
    }

</table>
