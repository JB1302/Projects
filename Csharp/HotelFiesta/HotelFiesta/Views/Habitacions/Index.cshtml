@model IEnumerable<HotelFiesta.Models.Habitacion>

@{
    ViewBag.Title = "Index";

    // Diccionario: HabitacionId -> Cantidad de reservas activas
    var reservasActivas = ViewBag.ReservasActivas as IDictionary<int, int>
        ?? new Dictionary<int, int>();
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>

<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.TipoHabitacion.Nombre)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.NumeroHabitacion)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.Piso)
        </th>

        <th>
            Reservas activas
        </th>

        <th>
            Imagen
        </th>

        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TipoHabitacion.Nombre)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.NumeroHabitacion)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.Piso)
            </td>

            <td>
                @(reservasActivas.TryGetValue(item.Id, out var c) ? c : 0)
            </td>

            <td>
                <img src="@Url.Content(item.ImagePath)"
                     alt="Imagen"
                     style="max-height:80px; max-width:120px; object-fit:cover;" />
            </td>

            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.Id })
            </td>
        </tr>
    }

</table>